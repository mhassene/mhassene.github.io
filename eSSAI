<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FileScope Pro — Retrouvez vos fichiers en un clin d'œil</title>
  <meta name="description" content="Recherchez vos fichiers Windows par nom, contenu, date de création/modification. OCR inclus. Téléchargez l'essai gratuit." />
  <style>
    /* ===== STYLES FLUENT ===== */
    :root {
      --bg: #0b1220;
      --bg2: #111a2e;
      --card: #121c33;
      --text: #eaf0ff;
      --muted: #b6c2e2;
      --line: #26324f;
      --accent: #4c7dff;
      --accent2: #7de2c7;
      --warn: #f5b301;
      --shadow: 0 18px 50px rgba(0,0,0,.28);
      --radius: 18px;
      --max: 1120px;
    }
    * { box-sizing:border-box; margin:0; padding:0; }
    body {
      background: radial-gradient(circle at top left, rgba(76,125,255,.18), transparent 30%),
                  radial-gradient(circle at top right, rgba(125,226,199,.12), transparent 25%),
                  var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, Arial, sans-serif;
      line-height:1.6;
    }
    a { text-decoration: none; color: inherit; }
    .wrap {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 22px;
    }
    .topbar {
      padding: 18px 0;
      border-bottom: 1px solid rgba(255,255,255,.08);
      background: rgba(8,13,25,.4);
      backdrop-filter: blur(12px);
      position: sticky;
      top:0;
      z-index:10;
    }
    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap:16px;
      flex-wrap: wrap;
    }
    .brand {
      font-weight: 800;
      font-size: 1.25rem;
      letter-spacing: .02em;
    }
    .navlinks {
      display: flex;
      gap: 22px;
      flex-wrap: wrap;
    }
    .navlinks a {
      font-size: 14px;
      color: var(--muted);
      transition: color .2s;
    }
    .navlinks a:hover { color: #fff; }
    .btn {
      display: inline-block;
      padding: 13px 28px;
      border-radius: 12px;
      background: var(--accent);
      color: #fff;
      font-weight: 700;
      box-shadow: 0 10px 26px rgba(76,125,255,.28);
      transition: transform .15s, box-shadow .15s;
    }
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 36px rgba(76,125,255,.35);
    }
    .btn.secondary {
      background: transparent;
      border: 1px solid rgba(255,255,255,.18);
      box-shadow: none;
    }
    .btn.secondary:hover {
      background: rgba(255,255,255,.05);
      transform: none;
    }
    .btn.big { font-size: 1.15rem; padding: 18px 40px; }

    .hero {
      padding: 50px 0 30px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      align-items: stretch;
    }
    .hero-col {
      background: linear-gradient(180deg, rgba(18,28,51,.95), rgba(14,22,40,.95));
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 28px 24px;
      box-shadow: var(--shadow);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .eyebrow {
      color: var(--accent2);
      text-transform: uppercase;
      letter-spacing: .12em;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 14px;
    }
    h1 {
      font-size: clamp(36px, 6vw, 58px);
      line-height: 1.03;
      margin: 0 0 16px;
    }
    .lead {
      font-size: 18px;
      color: var(--muted);
      margin: 0 0 22px;
    }
    .hero-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 20px;
    }
    .badge-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 22px;
    }
    .badge-grid span {
      padding: 8px 12px;
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 999px;
      background: rgba(255,255,255,.03);
      text-align: center;
      font-size: 13px;
      color: var(--muted);
      white-space: nowrap;
    }
    @media (max-width: 920px) {
      .hero { grid-template-columns:1fr; }
      .badge-grid span { white-space: normal; }
    }

    section { padding: 44px 0; }
    .section-title {
      font-size: 32px;
      line-height: 1.15;
      margin: 0 0 10px;
    }
    .section-sub {
      color: var(--muted);
      margin: 0 0 22px;
      max-width: 760px;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px,1fr));
      gap: 18px;
    }
    .card {
      background: linear-gradient(180deg, rgba(18,28,51,.98), rgba(13,20,36,.98));
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 22px;
      box-shadow: var(--shadow);
    }
    .card h3 { margin: 0 0 10px; font-size: 18px; }
    .card p { margin: 0; color: var(--muted); }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2,1fr);
      gap: 18px;
    }
    .feature-grid .card { border-left: 4px solid var(--accent); }

    .steps {
      display: grid;
      grid-template-columns: repeat(3,1fr);
      gap: 18px;
    }
    .step .num {
      width: 38px; height:38px; border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      background: rgba(76,125,255,.15);
      color: #cfe0ff;
      font-weight: 800;
      margin-bottom: 12px;
      border: 1px solid rgba(76,125,255,.25);
    }

    .testimonials {
      background: linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,.03));
      border-top: 1px solid rgba(255,255,255,.06);
      border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .stars { color: var(--warn); margin-bottom: 10px; font-size: 18px; }
    .quote { font-size: 15px; color: #e7eeff; margin: 0 0 14px; }
    .meta { color: var(--muted); font-size: 13px; }

    .faq {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }
    .faq-item h3 { margin: 0 0 8px; font-size: 18px; }
    .faq-item p { margin: 0; color: var(--muted); }

    .pricing {
      background: linear-gradient(180deg, rgba(76,125,255,.08), rgba(125,226,199,.06));
      border-radius: var(--radius);
      padding: 30px;
      text-align: center;
      border: 1px solid rgba(255,255,255,.08);
      box-shadow: var(--shadow);
    }
    .pricing .price {
      font-size: 42px;
      font-weight: 800;
      color: #fff;
      margin: 10px 0;
    }
    .pricing .price small {
      font-size: 18px;
      font-weight: 400;
      color: var(--muted);
    }
    .pricing ul {
      display: inline-block;
      text-align: left;
      margin: 20px auto;
      padding: 0;
      list-style: none;
      color: var(--muted);
    }
    .pricing ul li { margin: 6px 0; }
    .pricing ul li::before { content: "✓ "; color: var(--accent2); }

    .cta-box {
      background: linear-gradient(135deg, rgba(76,125,255,.16), rgba(125,226,199,.10));
      border: 1px solid rgba(255,255,255,.10);
      border-radius: 26px;
      padding: 40px 30px;
      text-align: center;
      margin-top: 30px;
    }

    footer {
      padding: 22px 0 38px;
      color: var(--muted);
      border-top: 1px solid rgba(255,255,255,.06);
      font-size: 14px;
    }
    .footer-row {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
    }
    .footer-links { display: flex; gap: 14px; flex-wrap: wrap; }

    @media (max-width: 920px) {
      .feature-grid, .steps, .faq { grid-template-columns: 1fr; }
      .nav { flex-direction: column; align-items: flex-start; }
